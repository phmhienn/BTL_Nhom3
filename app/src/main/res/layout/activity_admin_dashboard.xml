<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:paddingTop="40dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="KiKiFud"
            android:textSize="22sp"
            android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/btnManageFood"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/bg_food"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="12dp"
        android:clickable="true"
        android:foreground="?attr/selectableItemBackground"
        android:elevation="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Quản lý món"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Thêm / sửa / xoá món"
            android:textColor="#666"
            android:layout_marginTop="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- ===== QUẢN LÝ ĐƠN ===== -->
    <LinearLayout
        android:id="@+id/btnManageOrder"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/bg_food"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="12dp"
        android:clickable="true"
        android:foreground="?attr/selectableItemBackground"
        android:elevation="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Quản lý đơn"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Xem và xử lý đơn hàng"
            android:textColor="#666"
            android:layout_marginTop="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/btnManageUser"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/bg_food"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="12dp"
        android:clickable="true"
        android:foreground="?attr/selectableItemBackground"
        android:elevation="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Quản lý tài khoản"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Xem và xử lý tài khoản"
            android:textColor="#666"
            android:layout_marginTop="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/btnManageCategory"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/bg_food"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="12dp"
        android:clickable="true"
        android:foreground="?attr/selectableItemBackground"
        android:elevation="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Quản lý danh mục"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Thêm, sửa, xoá danh mục"
            android:textColor="#666"
            android:layout_marginTop="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đăng xuất"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:background="@color/primary"
            android:textColor="@android:color/white"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp"
            android:clickable="true"
            android:foreground="?attr/selectableItemBackground" />

</LinearLayout>