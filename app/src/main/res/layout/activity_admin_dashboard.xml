<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:paddingTop="40dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- TIÊU ĐỀ -->
    <TextView
        android:text="FastFood App"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- ===== QUẢN LÝ MÓN ===== -->
    <LinearLayout
        android:id="@+id/btnManageFood"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/bg_food"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="12dp"
        android:clickable="true"
        android:foreground="?attr/selectableItemBackground"
        android:elevation="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Quản lý món"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Thêm / sửa / xoá món"
            android:textColor="#666"
            android:layout_marginTop="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- ===== QUẢN LÝ ĐƠN ===== -->
    <LinearLayout
        android:id="@+id/btnManageOrder"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/bg_food"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="12dp"
        android:clickable="true"
        android:foreground="?attr/selectableItemBackground"
        android:elevation="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Quản lý đơn"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Xem và xử lý đơn hàng"
            android:textColor="#666"
            android:layout_marginTop="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</LinearLayout>