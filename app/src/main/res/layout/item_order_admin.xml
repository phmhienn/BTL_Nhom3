<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_margin="8dp"
    android:background="@drawable/bg_food"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- MÃ ĐƠN -->
    <TextView
        android:id="@+id/txtOrderId"
        android:text="Đơn #1"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="#000"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- KHÁCH -->
    <TextView
        android:id="@+id/txtUser"
        android:text="Khách: Nguyễn Văn A"
        android:layout_marginTop="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- ĐỊA CHỈ -->
    <TextView
        android:id="@+id/txtAddress"
        android:text="Địa chỉ: Hà Nội"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- DANH SÁCH MÓN -->
    <TextView
        android:id="@+id/txtItems"
        android:text="1. Burger (x2)"
        android:layout_marginTop="6dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- TỔNG TIỀN -->
    <TextView
        android:id="@+id/txtTotal"
        android:text="Tổng: 100000 VNĐ"
        android:textStyle="bold"
        android:layout_marginTop="6dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <TextView
        android:id="@+id/txtDate"
        android:text="Ngày đặt: 2026-01-01"
        android:textColor="#666"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- TRẠNG THÁI (CLICK ĐỂ MỞ MENU) -->
    <TextView
        android:id="@+id/txtStatus"
        android:text="Trạng thái: Đang xử lý"
        android:textStyle="bold"
        android:textColor="#2196F3"
        android:drawableEnd="@android:drawable/arrow_down_float"
        android:padding="6dp"
        android:layout_marginTop="8dp"
        android:background="@android:drawable/editbox_background"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

</LinearLayout>